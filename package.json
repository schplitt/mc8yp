{
  "name": "mc8yp",
  "version": "2.0.1",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Cumulocity IoT MCP Server - Model Context Protocol integration for IoT device management",
  "keywords": [
    "cumulocity",
    "c8y",
    "iot",
    "mcp",
    "model-context-protocol",
    "cli"
  ],
  "license": "MIT",
  "author": "schplitt",
  "homepage": "https://github.com/schplitt/mc8yp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/schplitt/mc8yp.git"
  },
  "bugs": {
    "url": "https://github.com/schplitt/mc8yp/issues"
  },
  "bin": {
    "mc8yp": "./dist/cli.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "creds-add": "pnpm dlx jiti ./src/cli/index.ts creds add",
    "creds-remove": "pnpm dlx jiti ./src/cli/index.ts creds remove",
    "creds-list": "pnpm dlx jiti ./src/cli/index.ts creds list",
    "build": "tsdown",
    "update:openapi": "node ./scripts/update-openapi.mjs",
    "package:microservices": "node ./scripts/package-microservices.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "test:bench": "vitest bench --run",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prerelease": "vitest run && eslint && tsc --noEmit && pnpm build",
    "release": "bumpp"
  },
  "dependencies": {
    "@c8y/client": "catalog:",
    "@napi-rs/keyring": "catalog:",
    "@tmcp/adapter-valibot": "catalog:",
    "@tmcp/transport-http": "catalog:",
    "@tmcp/transport-stdio": "catalog:",
    "@toon-format/toon": "catalog:",
    "bumpp": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:",
    "h3": "catalog:",
    "secure-exec": "catalog:",
    "tmcp": "catalog:",
    "ufo": "catalog:",
    "unctx": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@schplitt/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "changelogithub": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

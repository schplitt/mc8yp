{
  "name": "mc8yp",
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Cumulocity IoT MCP Server - Model Context Protocol integration for IoT device management",
  "keywords": [
    "cumulocity",
    "c8y",
    "iot",
    "mcp",
    "model-context-protocol",
    "cli"
  ],
  "license": "MIT",
  "author": "schplitt",
  "homepage": "https://github.com/schplitt/mc8yp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/schplitt/mc8yp.git"
  },
  "bugs": {
    "url": "https://github.com/schplitt/mc8yp/issues"
  },
  "bin": {
    "mc8yp": "./dist/cli.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "creds-add": "pnpm dlx jiti ./src/cli/index.ts creds add",
    "creds-remove": "pnpm dlx jiti ./src/cli/index.ts creds remove",
    "creds-list": "pnpm dlx jiti ./src/cli/index.ts creds list",
    "build": "tsdown",
    "update:openapi": "node ./scripts/update-openapi.mjs",
    "package:microservices": "node ./scripts/package-microservices.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "test:bench": "vitest bench --run",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prerelease": "vitest run && eslint && tsc --noEmit && pnpm build",
    "release": "bumpp"
  },
  "dependencies": {
    "@c8y/client": "^1023.68.7",
    "@napi-rs/keyring": "^1.2.0",
    "@tmcp/adapter-valibot": "^0.1.5",
    "@tmcp/transport-http": "^0.8.5",
    "@tmcp/transport-stdio": "^0.4.2",
    "@toon-format/toon": "^2.1.0",
    "bumpp": "^11.0.1",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "h3": "2.0.1-rc.6",
    "secure-exec": "^0.2.1",
    "tmcp": "^1.19.3",
    "ufo": "^1.6.3",
    "unctx": "^2.5.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@schplitt/eslint-config": "^1.4.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
